rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: decisions
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - decision: string (required) - Original prompt
    //   - type: string (required) - Analysis type (pros-cons, comparison, swot)
    //   - result: map (required) - Analysis result object
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDecision(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.decision is string && data.decision.size() > 0 && data.decision.size() < 5000 &&
             data.type in ['pros-cons', 'comparison', 'swot'] &&
             data.result is map &&
             data.createdAt is timestamp;
    }

    match /decisions/{decisionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidDecision(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false; // Decisions are immutable once saved
    }

    match /_test/connection {
      allow read: if true;
    }
  }
}
